{
    "name": "classsend",
    "version": "11.1.2",
    "description": "ClassSend - Local Network File Sharing for Education",
    "productName": "ClassSend",
    "author": "ClassSend Team",
    "main": "electron-main.js",
    "scripts": {
        "start": "electron .",
        "premake": "npm --prefix ../client run build",
        "make": "electron-builder --win --x64",
        "premake:win32": "npm --prefix ../client run build",
        "make:win32": "electron-builder --win --ia32",
        "generate-icon": "node convert-icon.js",
        "server": "node index.js",
        "dev": "node --watch index.js",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "build": {
        "appId": "com.classsend.app",
        "productName": "ClassSend",
        "icon": "./assets/icon.ico",
        "asar": true,
        "win": {
            "target": "nsis",
            "icon": "./assets/icon.ico"
        },
        "extraResources": [
            {
                "from": "wifi-guard.ps1",
                "to": "wifi-guard.ps1"
            }
        ],
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": false,
            "perMachine": true,
            "installerIcon": "./assets/icon.ico",
            "uninstallerIcon": "./assets/icon.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "ClassSend",
            "include": "installer.nsh"
        },
        "files": [
            "electron-main.js",
            "index.js",
            "config-manager.js",
            "network-discovery.js",
            "file-storage.js",
            "preload.js",
            "tls-config.js",
            "splash.html",
            "lib/**/*",
            "public/**/*",
            "assets/**/*",
            "data/**/*"
        ],
        "directories": {
            "output": "dist_build"
        }
    },
    "keywords": [
        "education",
        "file-sharing",
        "local-network",
        "classroom"
    ],
    "license": "GPL-3.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/kalotrapezis/ClassSend.git"
    },
    "type": "commonjs",
    "pkg": {
        "assets": [
            "public/**/*"
        ],
        "targets": [
            "node22-win-x64"
        ]
    },
    "dependencies": {
        "bad-words": "^3.0.4",
        "bayes": "^1.0.0",
        "bonjour-service": "^1.3.0",
        "cors": "^2.8.6",
        "express": "^4.19.2",
        "internal-ip": "^7.0.0",
        "multer": "^1.4.5-lts.1",
        "node-forge": "^1.3.3",
        "socket.io": "^4.8.1"
    },
    "devDependencies": {
        "electron": "^22.3.27",
        "electron-builder": "^24.13.3",
        "png-to-ico": "^2.0.4",
        "sharp": "^0.32.6"
    }
}